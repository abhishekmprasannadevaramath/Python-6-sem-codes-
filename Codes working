import math

d = [
    ['Rainy', 'Hot', 'Yes'],
    ['Sunny', 'Hot', 'No'],
    ['Sunny', 'Cool', 'No'],
    ['Rainy', 'Cool', 'Yes']
]

def e(data):
    y = [x[-1] for x in data]
    return sum(
        -(y.count(i) / len(y)) * math.log2(y.count(i) / len(y))
        for i in set(y)
    )

def id3(data, features, max_depth=99, depth=0):
    y = [x[-1] for x in data]

    if len(set(y)) == 1 or depth == max_depth:
        return max(set(y), key=y.count)

    best = max(
        features,
        key=lambda a: e(data) - sum(
            len(s) / len(data) * e(s)
            for v in set(x[a] for x in data)
            for s in [[x for x in data if x[a] == v]]
        )
    )

    return {
        best: {
            v: id3(
                [x for x in data if x[best] == v],
                [x for x in features if x != best],
                max_depth,
                depth + 1
            )
            for v in set(x[best] for x in data)
        }
    }

print("UNDERFITTING")
print(id3(d, [0, 1], 1))

print("\nBALANCED")
print(id3(d, [0, 1], 2))

print("\nOVERFITTING")
print(id3(d, [0, 1]))


