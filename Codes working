 import numpy as np

x = np.array([
    [8.3,52.1,9],[8.3,42.1,2],
    [6.3,52.1,2],[6.8,52.1,4],
    [6.8,42.1,9],[7.3,52.8,7],
    [8.3,52.4,2],[8.3,52.4,7],
    [8.3,52.2,9],[8.3,52.4,2]
])

y = np.array([4.5,3.5,3.5,3.4,3.4,2.6,2.9,2.4,2.2,2.6])

tx, vx = x[:8], x[8:]
ty, vy = y[:8], y[8:]

m, s = tx.mean(0), tx.std(0)

tx = (tx - m) / s
vx = (vx - m) / s

tx = np.c_[np.ones(len(tx)), tx]
vx = np.c_[np.ones(len(vx)), vx]

theta = np.linalg.inv(tx.T @ tx) @ tx.T @ ty

pred = vx @ theta

mse = np.mean((vy - pred) ** 2)

print("Predictions\n")

for i in range(len(pred)):
    print("Actual:", vy[i])
    print("Prediction:", round(pred[i], 2))
    print()

print("MSE =", round(mse, 2))
print("RMSE =", round(np.sqrt(mse), 2))




