def ce(d):
    s = ['0'] * 4
    g = [['?', '?', '?', '?']]

    print("\nInitial Specific Hypothesis:", s)
    print("Initial General Hypothesis:", g)

    for x in d:
        if x[-1] == "yes":
            for i in range(4):
                if s[i] == '0':
                    s[i] = x[i]
                elif s[i] != x[i]:
                    s[i] = '?'

    return s, g

