d = [
    ['youth','high','no','fair','no'],
    ['youth','high','no','excellent','no'],
    ['senior','high','yes','fair','yes'],
    ['senior','high','yes','fair','yes']
]

def find_s(d):
    h = ['0'] * 4
    print("Initial Hypothesis:", h)

    for x in d:
        if x[-1] == "yes":
            for i in range(4):
                if h[i] == '0':
                    h[i] = x[i]
                elif h[i] != x[i]:
                    h[i] = '?'
    return h

def ce(d):
    s = ['0'] * 4
    g = [['?', '?', '?', '?']]

    print("\nInitial Specific Hypothesis:", s)
    print("Initial General Hypothesis:", g)

    for x in d:
        if x[-1] == "yes":
            for i in range(4):
                if s[i] == '0':
                    s[i] = x[i]
                elif s[i] != x[i]:
                    s[i] = '?'

    return s, g

print("===== FIND-S ALGORITHM =====")
h = find_s(d)
print("\nFinal Hypothesis from Find-S:")
print(h)

print("\n===== CANDIDATE ELIMINATION ALGORITHM =====")
s, g = ce(d)

print("\nFinal Specific Hypothesis:")
print(s)

print("\nFinal General Hypothesis:")
for i in g:
    print(i)
