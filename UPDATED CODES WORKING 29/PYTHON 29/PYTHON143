# Expt 1: To solve the Tic-Tac-Toe problem using the Depth First Search Technique

w = [(0,1,2), (3,4,5), (6,7,8),
     (0,3,6), (1,4,7), (2,5,8),
     (0,4,8), (2,4,6)]

def show(b):
    for i in range(0,9,3):
        print(b[i], "|", b[i+1], "|", b[i+2])
    print()

def win(b, p):
    return any(b[x] == b[y] == b[z] == p for x,y,z in w)

def mm(b, m):
    if win(b, 'X'):
        return 1
    if win(b, 'O'):
        return -1

    e = [i for i in range(9) if b[i] == ' ']

    if not e:
        return 0

    s = []

    for i in e:
        b[i] = 'X' if m else 'O'
        s.append(mm(b, not m))
        b[i] = ' '

    return max(s) if m else min(s)

def best(b):
    move, val = -1, -2

    for i in range(9):
        if b[i] == ' ':
            b[i] = 'X'
            v = mm(b, False)
            b[i] = ' '

            if v > val:
                val, move = v, i

    return move

b = [' '] * 9

while True:

    show(b)

    p = int(input("Enter position (0-8): "))

    if b[p] != ' ':
        print("Invalid Move")
        continue

    b[p] = 'O'

    if win(b, 'O'):
        show(b)
        print("You Win!")
        break

    if ' ' not in b:
        show(b)
        print("Draw!")
        break

    c = best(b)
    b[c] = 'X'

    print("Computer choose:", c)

    if win(b, 'X'):
        show(b)
        print("Computer Wins!")
        break

    if ' ' not in b:
        show(b)
        print("Draw!")
        break









